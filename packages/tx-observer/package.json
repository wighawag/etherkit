{
	"name": "@etherkit/tx-observer",
	"version": "0.0.8",
	"description": "A lightweight TypeScript library for tracking and monitoring Ethereum transactions throughout their lifecycle",
	"keywords": [
		"ethereum",
		"transaction",
		"observer",
		"monitor",
		"tracker",
		"blockchain",
		"web3",
		"typescript",
		"reactive",
		"eip-1193"
	],
	"license": "MIT",
	"author": "Ronan Sandford",
	"homepage": "https://github.com/wighawag/etherkit#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wighawag/etherkit.git",
		"directory": "packages/tx-observer"
	},
	"bugs": {
		"url": "https://github.com/wighawag/etherkit/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"sideEffects": false,
	"dependencies": {
		"lodash-es": "^4.17.23",
		"named-logs": "^0.4.1",
		"radiate": "^0.3.2"
	},
	"devDependencies": {
		"@types/lodash-es": "^4.17.12",
		"@vitest/coverage-v8": "^4.0.18",
		"as-soon": "^0.1.5",
		"eip-1193": "^0.6.5",
		"prettier": "^3.8.0",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"build": "tsc",
		"dev": "as-soon -w src pnpm build",
		"typecheck": "tsc --noEmit -p tsconfig-check.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	}
}
